{
	"name": "microtastic",
	"version": "0.0.71",
	"description": "Small tooling package for pure ES6 browser development.",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"format": "biome format --write .",
		"check": "biome check .",
		"test": "node --test",
		"prepare": "husky",
		"docs": "jsdoc -c jsdoc.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/seriva/microtastic.git"
	},
	"keywords": [
		"ES6"
	],
	"bin": {
		"microtastic": "index.js"
	},
	"exports": {
		"./reactive": "./reactive.js"
	},
	"author": "Luuk van Venrooij",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/seriva/microtastic/issues"
	},
	"homepage": "https://github.com/seriva/microtastic#readme",
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"husky": "^9.1.7",
		"jsdoc": "^4.0.5",
		"jsdom": "^29.0.1"
	},
	"dependencies": {
		"@rolldown/plugin-node-polyfills": "^1.0.3",
		"rolldown": "^1.0.0-rc.13"
	},
	"publishConfig": {
		"access": "public"
	}
}
